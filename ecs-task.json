{
  "family": "scitext-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::713279244798:role/labRole",
  "taskRoleArn": "arn:aws:iam::713279244798:role/labRole",
  "containerDefinitions": [
    {
      "name": "mlflow",
      "image": "713279244798.dkr.ecr.us-east-1.amazonaws.com/scitext-mlflow:latest",
      "portMappings": [{ "containerPort": 5006, "protocol": "tcp" }],
      "essential": true
    },
    {
      "name": "ollama",
      "image": "713279244798.dkr.ecr.us-east-1.amazonaws.com/scitext-ollama-proxy:latest",
      "portMappings": [{ "containerPort": 11434, "protocol": "tcp" }],
      "environment": [
        { "name": "OPENROUTER_API_KEY", "value": "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" },
        { "name": "OPENROUTER_MODEL", "value": "meta-llama/llama-3.1-8b-instruct" },
        { "name": "OPENROUTER_PROVIDER_ONLY", "value": "open-inference" },
        { "name": "OPENROUTER_QUANTIZATIONS", "value": "int8" },
        { "name": "OPENROUTER_ALLOW_FALLBACKS", "value": "0" }
      ],
      "essential": true
    },
    {
      "name": "backend",
      "image": "713279244798.dkr.ecr.us-east-1.amazonaws.com/scitext-backend:latest",
      "portMappings": [{ "containerPort": 5000, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "5000" },
        { "name": "MLFLOW_TRACKING_URI", "value": "http://127.0.0.1:5006" },
        { "name": "OLLAMA_BASE_URL", "value": "http://127.0.0.1:11434" }
      ],
      "essential": true
    }
  ]
}
